# ── Africa's Talking ────────────────────────────────────────────────────────
# Use "sandbox" for local testing — SMS will be logged to console
AT_API_KEY=sandbox
AT_USERNAME=sandbox
AT_SENDER_ID=VeriFarm
AT_PAYMENT_PRODUCT=VeriFarm

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Local: create DB with: createdb verifarm_ussd
DATABASE_URL=postgresql://postgres:password@localhost:5432/verifarm_ussd

# ── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Oracle ───────────────────────────────────────────────────────────────────
# Secret for POST /oracle/score — set to anything strong in production
ORACLE_SECRET=dev-secret
# Base58-encoded oracle keypair secret key (registered on-chain by admin)
# Generate: solana-keygen new --outfile oracle.json && cat oracle.json
ORACLE_KEYPAIR_BASE58=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
